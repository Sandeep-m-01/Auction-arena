<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <!-- ================================================= -->
    <!-- BACKGROUND -->
    <!-- ================================================= -->

    <ImageView
        android:id="@+id/imgAuctionBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/home"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- ================================================= -->
    <!-- DARK OVERLAY -->
    <!-- ================================================= -->

    <View
        android:id="@+id/backgroundOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#B8000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- ================================================= -->
    <!-- TOP BAR -->
    <!-- ================================================= -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <!-- BLINKING RED DOT -->

        <View
            android:id="@+id/liveDot"
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:background="@drawable/live_dot"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />


        <!-- LIVE TEXT -->

        <TextView
            android:id="@+id/txtLive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"
            android:text="LIVE"
            android:fontFamily="@font/bebas_neue"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/liveDot"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />


        <!-- AUCTION ARENA TITLE -->

        <TextView
            android:id="@+id/txtAuctionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUCTION ARENA"
            android:textColor="#D4AF37"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/bebas_neue"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />


        <!-- REMAINING BUDGET -->

        <TextView
            android:id="@+id/txtRemainingBudget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$1000M"
            android:fontFamily="@font/bebas_neue"
            android:textColor="#D4AF37"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>


    <!-- TOP GOLD DIVIDER -->

    <View
        android:id="@+id/topDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#55D4AF37"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- ================================================= -->
    <!-- SCROLLABLE MAIN CONTENT -->
    <!-- ================================================= -->

    <ScrollView
        android:id="@+id/auctionScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/topDivider"
        app:layout_constraintBottom_toTopOf="@id/bottomDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="580dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp">


            <!-- ================================================= -->
            <!-- PLAYER CARD -->
            <!-- ================================================= -->

            <FrameLayout
                android:id="@+id/playerCard"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="260dp"
                android:maxHeight="430dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/player_card_border"
                android:clipToOutline="true">


                <!-- PLAYER IMAGE -->

                <ImageView
                    android:id="@+id/imgAuctionPlayer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:adjustViewBounds="true"
                    android:padding="12dp"
                    android:contentDescription="@null" />


                <!-- BLACK FADE OVER IMAGE -->

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/player_card_gradient" />


                <!-- PLAYER INFORMATION -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="22dp">


                    <TextView
                        android:id="@+id/txtAuctionPlayerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#FFFFFF"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/bebas_neue" />


                    <TextView
                        android:id="@+id/txtPlayerPosition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text=""
                        android:textColor="#D4AF37"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center" />


                </LinearLayout>


                <!-- SOLD OVERLAY -->

                <TextView
                    android:id="@+id/txtSoldOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="SOLD"
                    android:textColor="#D4AF37"
                    android:textSize="58sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/bebas_neue"
                    android:background="#99000000"
                    android:visibility="gone" />


            </FrameLayout>


            <!-- ================================================= -->
            <!-- CURRENT BID LABEL -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="CURRENT BID"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />


            <!-- CURRENT BID -->

            <TextView
                android:id="@+id/txtCurrentBid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="$0M"
                android:textColor="#D4AF37"
                android:textSize="34sp"
                android:textStyle="bold"
                android:fontFamily="@font/bebas_neue" />


            <!-- SMALL GOLD LINE -->

            <View
                android:layout_width="70dp"
                android:layout_height="2dp"
                android:layout_marginTop="5dp"
                android:background="#D4AF37" />


            <!-- HIGHEST BIDDER LABEL -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="HIGHEST BIDDER"
                android:textColor="#88FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.10" />


            <!-- HIGHEST BIDDER -->

            <TextView
                android:id="@+id/txtHighestBidder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="NO BIDS YET"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="2" />


            <!-- ================================================= -->
            <!-- BID INPUT -->
            <!-- ================================================= -->

            <EditText
                android:id="@+id/etBidAmount"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bid_input_background"
                android:hint="ENTER BID AMOUNT ($M)"
                android:textColor="#FFFFFF"
                android:textColorHint="#88FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:inputType="number"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true" />


            <!-- ================================================= -->
            <!-- BUTTONS -->
            <!-- ================================================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="2">


                <!-- BID BUTTON -->

                <TextView
                    android:id="@+id/btnBid"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bid_button_background"
                    android:gravity="center"
                    android:text="BID $"
                    android:textColor="#000000"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />


                <!-- GIVE UP BUTTON -->

                <TextView
                    android:id="@+id/btnGiveUp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/give_up_button_background"
                    android:gravity="center"
                    android:text="GIVE UP"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />


            </LinearLayout>


            <!-- ================================================= -->
            <!-- SWIPE INDICATOR -->
            <!-- ================================================= -->

            <TextView
                android:id="@+id/txtSwipeTeam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp"
                android:text="◀  SWIPE FOR MY TEAM"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />


        </LinearLayout>


    </ScrollView>


    <!-- ================================================= -->
    <!-- BOTTOM GOLD DIVIDER -->
    <!-- ================================================= -->

    <View
        android:id="@+id/bottomDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#55D4AF37"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- ================================================= -->
    <!-- FOOTER -->
    <!-- ================================================= -->

    <TextView
        android:id="@+id/footer"
        android:layout_width="0dp"
        android:layout_height="42dp"
        android:gravity="center"
        android:text="AUCTION ARENA"
        android:textColor="#55D4AF37"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="@font/bebas_neue"
        android:letterSpacing="0.15"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>