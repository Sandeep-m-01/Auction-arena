<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ============================================ -->
    <!-- BACKGROUND -->
    <!-- ============================================ -->

    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/home"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- ============================================ -->
    <!-- DARK CINEMATIC OVERLAY -->
    <!-- ============================================ -->

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#90000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- ============================================ -->
    <!-- MAIN CONTENT -->
    <!-- ============================================ -->

    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <!-- ======================================== -->
        <!-- SMALL BRAND TEXT -->
        <!-- ======================================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WELCOME TO"
            android:textColor="#C9A227"
            android:textSize="15sp"
            android:letterSpacing="0.20"
            android:fontFamily="@font/bebas_neue" />


        <!-- ======================================== -->
        <!-- MAIN TITLE -->
        <!-- ======================================== -->

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="AUCTION ARENA"
            android:textColor="#FFFFFF"
            android:textSize="58sp"
            android:textStyle="bold"
            android:fontFamily="@font/bebas_neue"
            android:gravity="center"
            android:letterSpacing="0.04"
            android:shadowColor="#FF000000"
            android:shadowDx="0"
            android:shadowDy="3"
            android:shadowRadius="8" />


        <!-- ======================================== -->
        <!-- GOLD LINE -->
        <!-- ======================================== -->

        <View
            android:layout_width="65dp"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="#C9A227" />


        <!-- ======================================== -->
        <!-- SUBTITLE -->
        <!-- ======================================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="BUILD YOUR DREAM TEAM"
            android:textColor="#99FFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.14"
            android:fontFamily="@font/bebas_neue" />


        <!-- ======================================== -->
        <!-- SPACE BETWEEN TITLE AND ACTIONS -->
        <!-- ======================================== -->

        <Space
            android:layout_width="match_parent"
            android:layout_height="100dp" />


        <!-- ======================================== -->
        <!-- CREATE ROOM BUTTON -->
        <!-- ======================================== -->

        <LinearLayout
            android:id="@+id/btnCreateRoom"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:background="@drawable/royal_gold_button"
            android:clickable="true"
            android:focusable="true"
            android:elevation="8dp">


            <!-- BUTTON TEXT -->

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CREATE ROOM"
                android:textColor="#080808"
                android:textStyle="bold"
                android:textSize="24sp"
                android:letterSpacing="0.08"
                android:fontFamily="@font/bebas_neue" />


            <!-- ARROW -->

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow"
                android:contentDescription="@null"
                app:tint="#080808" />


        </LinearLayout>


        <!-- ======================================== -->
        <!-- SPACE -->
        <!-- ======================================== -->

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />


        <!-- ======================================== -->
        <!-- JOIN ROOM BUTTON -->
        <!-- ======================================== -->

        <LinearLayout
            android:id="@+id/btnJoinRoom"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:background="@drawable/dark_button"
            android:clickable="true"
            android:focusable="true"
            android:elevation="6dp">


            <!-- BUTTON TEXT -->

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="JOIN ROOM"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="24sp"
                android:letterSpacing="0.08"
                android:fontFamily="@font/bebas_neue" />


            <!-- ARROW -->

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow"
                android:contentDescription="@null"
                app:tint="#C9A227" />


        </LinearLayout>


        <!-- ======================================== -->
        <!-- BOTTOM TEXT -->
        <!-- ======================================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="CREATE • BID • BUILD • WIN"
            android:textColor="#66FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.14"
            android:fontFamily="@font/bebas_neue" />


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>