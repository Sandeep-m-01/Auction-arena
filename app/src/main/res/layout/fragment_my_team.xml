<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ================================================= -->
    <!-- BACKGROUND -->
    <!-- ================================================= -->

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/home"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Dark overlay -->

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B0000000" />


    <!-- ================================================= -->
    <!-- MAIN CONTENT -->
    <!-- ================================================= -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="45dp"
        android:paddingBottom="25dp">


        <!-- ================================================= -->
        <!-- HEADER -->
        <!-- ================================================= -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUCTION ARENA"
            android:textColor="#D4AF37"
            android:textSize="16sp"
            android:fontFamily="@font/bebas_neue"
            android:letterSpacing="0.12" />


        <TextView
            android:id="@+id/txtMyTeamTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MY TEAM"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:textStyle="bold"
            android:fontFamily="@font/bebas_neue"
            android:letterSpacing="0.05" />


        <View
            android:layout_width="55dp"
            android:layout_height="3dp"
            android:layout_marginTop="5dp"
            android:background="#D4AF37" />


        <!-- ================================================= -->
        <!-- TEAM INFO -->
        <!-- ================================================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="horizontal">


            <!-- BUDGET -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/menu_card">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BUDGET"
                    android:textColor="#AAFFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/bebas_neue"
                    android:letterSpacing="0.1" />


                <TextView
                    android:id="@+id/txtTeamBudget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$1000M"
                    android:textColor="#D4AF37"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/bebas_neue" />

            </LinearLayout>


            <Space
                android:layout_width="12dp"
                android:layout_height="match_parent" />


            <!-- PLAYER COUNT -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/menu_card">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLAYERS"
                    android:textColor="#AAFFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/bebas_neue"
                    android:letterSpacing="0.1" />


                <TextView
                    android:id="@+id/txtPlayerCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/bebas_neue" />

            </LinearLayout>

        </LinearLayout>


        <!-- ================================================= -->
        <!-- SQUAD TITLE -->
        <!-- ================================================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:text="YOUR SQUAD"
            android:textColor="#FFFFFF"
            android:textSize="21sp"
            android:textStyle="bold"
            android:fontFamily="@font/bebas_neue"
            android:letterSpacing="0.08" />


        <!-- ================================================= -->
        <!-- PLAYER LIST -->
        <!-- ================================================= -->

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:fillViewport="true"
            android:scrollbars="none">


            <LinearLayout
                android:id="@+id/teamPlayersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">


                <!-- EMPTY TEAM MESSAGE -->

                <TextView
                    android:id="@+id/txtEmptyTeam"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:gravity="center"
                    android:text="NO PLAYERS YET&#10;WIN AN AUCTION TO BUILD YOUR TEAM"
                    android:textColor="#88FFFFFF"
                    android:textSize="17sp"
                    android:fontFamily="@font/bebas_neue"
                    android:letterSpacing="0.05"
                    android:textAlignment="center" />


            </LinearLayout>

        </ScrollView>


        <!-- ================================================= -->
        <!-- SWIPE HINT -->
        <!-- ================================================= -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="‹  SWIPE BACK TO AUCTION"
            android:textColor="#88FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/bebas_neue"
            android:letterSpacing="0.08"
            android:layout_marginTop="10dp" />


    </LinearLayout>

</FrameLayout>